# ChronoCare AI - Git Ignore
# Prevents committing sensitive and unnecessary files

# Environment Variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv
virtualenv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
*.log.*

# Models and Data (Large files)
models/
*.bin
*.pt
*.pth
*.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/

# Docker
.dockerignore
*.dockerfile

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
tmp/
temp/

# API Keys and Secrets (NEVER commit these!)
secrets.txt
credentials.json
*.key
*.pem

# Node (if any frontend in this directory)
node_modules/
package-lock.json
npm-debug.log

# Database
*.db
*.sqlite
*.sqlite3
